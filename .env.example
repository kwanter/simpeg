APP_NAME="Sistem Informasi Pegawai"
APP_ENV=local
APP_KEY=
# Production: APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-domain
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta
APP_PORT=8000
# Production Docker Nginx: loopback-only upstream for host Caddy
APP_HTTP_PORT=8080
POSTGRES_DATABASE=simpeg
POSTGRES_USERNAME=simpeg
POSTGRES_PASSWORD=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=simpeg
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Production behind HTTPS: SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=false
# Behind reverse proxy/LB: TRUSTED_PROXIES=* or comma-separated IPs
TRUSTED_PROXIES=

MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211

REDIS_HOST=127.0.0.1
# Production: required by compose.prod.yaml
REDIS_PASSWORD=
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Production bootstrap super-admin — seed once, then clear the password
SEEDER_SUPERADMIN_EMAIL=superadmin@simpeg.local
SEEDER_DEFAULT_PASSWORD=
